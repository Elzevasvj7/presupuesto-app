generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DIRECT_URL")
}

model BudgetItem {
  id        Int      @id @default(autoincrement())
  name      String // Nombre del presupuesto
  category  String // Categoría (comida, transporte, ropa, etc.)
  amount    Float // Monto asignado
  note      String? // Descripción opcional
  userId    String // ID del usuario de Supabase Auth
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model Budget {
  id        Int      @id @default(autoincrement())
  amount    Float // Monto total del presupuesto
  userId    String   @unique // Un presupuesto por usuario
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model Transaction {
  id          Int      @id @default(autoincrement())
  description String // Descripción de la transacción
  amount      Float // Monto de la transacción
  type        String // Tipo: 'income' o 'expense'
  category    String // Categoría (comida, transporte, salario, etc.)
  date        DateTime @default(now()) // Fecha de la transacción
  userId      String // ID del usuario de Supabase Auth
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
}
