// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DIRECT_URL")
}

model BudgetItem {
  id        Int      @id @default(autoincrement())
  name      String // Nombre del presupuesto
  category  String // Categoría (comida, transporte, ropa, etc.)
  amount    Float // Monto asignado
  note      String? // Descripción opcional
  userId    String // ID del usuario de Supabase Auth
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model Budget {
  id        Int      @id @default(autoincrement())
  amount    Float // Monto total del presupuesto
  userId    String   @unique // Un presupuesto por usuario
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model Transaction {
  id          Int      @id @default(autoincrement())
  description String // Descripción de la transacción
  amount      Float // Monto de la transacción
  type        String // Tipo: 'income' o 'expense'
  balanceType String   @default("digital") // Medio del saldo: cash o digital
  category    String // Categoría (comida, transporte, salario, etc.)
  date        DateTime @default(now()) // Fecha de la transacción
  userId      String // ID del usuario de Supabase Auth
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
}

model BinanceCredential {
  id                    Int      @id @default(autoincrement())
  userId                String   @unique // Unas credenciales Binance por usuario
  apiKeyEncrypted       String
  apiKeyIv              String
  apiKeyAuthTag         String
  apiSecretEncrypted    String
  apiSecretIv           String
  apiSecretAuthTag      String
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([userId])
}

model BinanceBalanceSnapshot {
  id            Int      @id @default(autoincrement())
  userId        String
  totalUsd      Float
  assetsCount   Int
  balancesJson  String // JSON serializado para mantener esquema simple
  capturedAt    DateTime @default(now())

  @@index([userId])
  @@index([capturedAt])
}
